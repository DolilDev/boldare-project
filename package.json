{
  "name": "solar-copilot",
  "version": "1.0.0",
  "private": true,
  "description": "Agentowy asystent dla energetyki słonecznej — web-app (Next.js) + serwer MCP, wspólny rejestr narzędzi na danych Open-Meteo.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "build:mcp": "esbuild mcp-server/server.ts --bundle --platform=node --format=cjs --target=node18 --outfile=mcp-server/dist/server.js",
    "mcp": "node mcp-server/dist/server.js"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.3"
  }
}
